    "sglawwatch": {
      "title": "SG Law Watch",
      "description": "Singapore legal news, FAQ, and reference materials.",
      "tables": {
        "_zeeker_schemas": {
          "hidden": true
        },
        "_zeeker_updates": {
          "hidden": true
        },
        "metadata": {
          "hidden": true
        },
        "schema_versions": {
          "hidden": true
        },
        "about_singapore_law_fragments": {
          "hidden": true
        },
        "headlines": {
          "sort_desc": "date",
          "title": "Headlines",
          "description": "Daily Singapore legal news headlines from major outlets.",
          "display": {
            "table_mode": "feed",
            "row_mode": "article",
            "columns": {
              "kicker": "category",
              "title": "title",
              "byline": "author",
              "body": "summary",
              "date": "date",
              "source_url": "source_link"
            }
          }
        },
        "about_singapore_law": {
          "title": "About Singapore Law",
          "description": "Catalogue of reference chapters on Singapore legal topics. Full text is indexed for search but not distributed; read each chapter at its source URL.",
          "display": {
            "table_mode": "feed",
            "row_mode": "article",
            "columns": {
              "kicker": "section",
              "title": "title",
              "date": "last_scraped",
