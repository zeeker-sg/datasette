{
  "title": "data.zeeker.sg",
  "description": "Open data platform for exploration, analysis, and programmatic access",
  "license": "CC-BY-4.0",
  "license_url": "https://creativecommons.org/licenses/by/4.0/",
  "source": "Various curated sources",
  "source_url": "https://data.zeeker.sg/sources",
  "about": "Providing free access to structured data for research, analysis, and application development",
  "about_url": "https://data.zeeker.sg/about",
  "allow_sql": {"id": "owner"},
  "databases": {
    "sg-gov-newsrooms": {
      "title": "SG Government Newsrooms",
      "description": "News and announcements from Singapore government ministries and the judiciary — press releases, speeches, parliamentary replies, and court announcements.",
      "license": "All rights reserved",
      "license_url": "https://www.mlaw.gov.sg/terms-of-use/",
      "source": "Singapore Government Ministries & Judiciary",
      "source_url": "https://www.mlaw.gov.sg/news/",
      "tables": {
        "_zeeker_schemas": {
          "hidden": true
        },
        "_zeeker_updates": {
          "hidden": true
        },
        "mlaw_news": {
          "sort_desc": "published_date",
          "title": "Ministry of Law News",
          "description": "Press releases, speeches, parliamentary speeches, and announcements from the Ministry of Law Singapore (2026 onwards). Full article text is indexed for search but not distributed; read the original at source_url. The AI-generated summary is provided for browsing.",
          "columns": {
            "id": "Unique identifier (SHA-256 hash of source URL)",
            "title": "Title of the news item or speech",
            "published_date": "Publication date (YYYY-MM-DD)",
            "category": "Content type: press-releases, speeches, parliamentary-speeches, announcements",
            "source_url": "URL to the original page on mlaw.gov.sg",
            "summary": "AI-generated summary highlighting key policy and legal points (~100 words)",
            "content_text": "Full extracted article text (indexed for search only — not distributed; read the original at source_url)",
            "created_at": "Timestamp when this record was first imported"
          },
          "display": {
            "table_mode": "feed",
            "row_mode": "article",
            "columns": {
              "kicker": "category",
              "title": "title",
              "byline": "published_date",
              "body": "summary",
              "date": "published_date",
              "source_url": "source_url"
            }
          }
        },
        "judiciary_news": {
          "sort_desc": "published_date",
          "title": "Singapore Judiciary News",
          "description": "News, speeches, and media releases from the Singapore Judiciary — Supreme Court, State Courts, Family Justice Courts, and related tribunals. Covers significant rulings, practice directions, speeches, and court administration updates.",
          "columns": {
            "id": "Unique identifier (SHA-256 hash of source URL)",
            "title": "Title of the news item, speech, or media release",
            "published_date": "Publication date (YYYY-MM-DD)",
            "content_type": "Type of item: Speech, Media Release, Media Advisory, etc.",
            "courts": "Pipe-separated court names (e.g. Supreme Court|State Courts)",
            "source_url": "URL to the original page on judiciary.gov.sg",
            "summary": "AI-generated summary highlighting key judicial developments (~100 words)",
            "content_text": "Full extracted text (indexed for search only — not distributed; read the original at source_url)",
            "created_at": "Timestamp when this record was first imported"
          },
          "display": {
            "table_mode": "feed",
            "row_mode": "article",
            "columns": {
              "kicker": "content_type",
              "title": "title",
              "byline": "published_date",
              "body": "summary",
              "date": "published_date",
              "source_url": "source_url"
            }
          }
        },
