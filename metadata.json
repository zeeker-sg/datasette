    "zeeker-judgements": {
      "title": "Zeeker Judgements",
      "description": "Singapore court judgments — Court of Appeal, High Court, State Courts.",
      "tables": {
        "_zeeker_schemas": {
          "hidden": true
        },
        "_zeeker_updates": {
          "hidden": true
        },
        "judgments_fragments": {
          "hidden": true
        },
        "judgments": {
          "sort_desc": "decision_date",
          "title": "Judgments",
          "description": "Singapore court judgments with summary, parties, and citation. Full judgment text is indexed for search but not distributed; read the full judgment at source_url.",
          "display": {
            "table_mode": "feed",
            "row_mode": "judgment",
            "columns": {
              "title": "case_name",
              "kicker": "court",
              "byline": "citation",
              "citation": "citation",
              "date": "decision_date",
              "body": "summary",
              "source_url": "source_url"
            }
          }
        }
      }
    },
    "pdpc": {
      "title": "PDPC Enforcement Decisions",
      "description": "Enforcement decisions published by Singapore's Personal Data Protection Commission.",
      "source": "Personal Data Protection Commission",
      "source_url": "https://www.pdpc.gov.sg/all-commissions-decisions",
      "tables": {
        "_zeeker_schemas": {
          "hidden": true
        },
        "_zeeker_updates": {
          "hidden": true
        },
        "enforcement_decisions_fragments": {
          "hidden": true
        },
        "enforcement_decisions": {
          "sort_desc": "decision_date",
          "title": "Enforcement Decisions",
          "description": "PDPC enforcement decisions with organisation, decision type, penalty, and summary. Decision text is indexed for search but not distributed; read the full decision at decision_url.",
          "display": {
            "table_mode": "feed",
            "row_mode": "article",
            "columns": {
              "kicker": "decision_type",
              "title": "title",
              "byline": "organisation",
              "body": "summary",
              "date": "decision_date",
              "source_url": "decision_url"
            }
          }
        }
      }
    }
  },
  "plugins": {
    "datasette-search-all": {
      "template": "Search across all available data"
    },
    "strip-columns": {
      "default_deny_names": [
        "content_text",
        "full_text",
        "html_raw",
        "footnote_text"
      ],
      "tables": {
        "sg-gov-newsrooms": {
          "acra_news": ["content_text"],
          "agc_news": ["content_text"],
          "ccs_news": ["content_text"],
          "ipos_news": ["content_text"],
          "judiciary_news": ["content_text"],
          "mlaw_news": ["content_text"],
          "mom_news": ["content_text"],
          "pdpc_news": ["content_text"]
        },
        "sglawwatch": {
          "commentaries": ["full_text"],
          "headlines": ["text"],
          "about_singapore_law": ["content"],
          "about_singapore_law_fragments": ["content_text"]
        },
        "zeeker-judgements": {
          "judgments": ["content_text"],
          "judgments_fragments": ["content_text", "html_raw", "footnote_text"]
        },
        "pdpc": {
          "enforcement_decisions_fragments": ["text"]
        }
      }
    }
  },
