# S3 Configuration
S3_BUCKET=your-bucket-name
S3_PREFIX=optional/path/prefix
AWS_REGION=default
S3_ENDPOINT_URL=https://s3.amazonaws.com

# AWS Credentials
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Zeeker Directory Paths
DATASETTE_DATABASE_DIR=/data
DATASETTE_TEMPLATE_DIR=/app/templates
DATASETTE_PLUGINS_DIR=/app/plugins
DATASETTE_STATIC_DIR=/app/static
DATASETTE_METADATA=/app/metadata.json

# Optional Datasette Configuration
# DATASETTE_SECRET=random-secret-key
# DATASETTE_CORS=true
# Owner full-access token (catalogue lockdown bypass).
# Requests to the data API with "Authorization: Bearer <this value>" receive
# full, unstripped content including CSV and arbitrary SQL. Generate with:
#   openssl rand -hex 32
# Leave unset to disable the bypass entirely.
ZEEKER_FULL_ACCESS_TOKEN=
