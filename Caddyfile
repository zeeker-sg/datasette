# zeeker-datasette — root Caddyfile
#
# Phase 3 of milestone M2 (Frontend / API Split).
# Role: suffix-based router. Caddy decides upstream by URL pattern.
#
#   *.json | *.csv | /-/*   →  zeeker-datasette:8001 (data API)
#   everything else         →  frontend:8000 (HTML; mostly 404 until
#                              Phase 4-6 port routes)
#
# NOTE: *.db was removed from the matcher (content lockdown). Database
# downloads are disabled (allow_download off); .db URLs now fall through
# to the frontend, which 404s them. Keep this matcher byte-parallel with
# Caddyfile.prod (REQ-api-byte-parity).
#
# Phase-D defence-in-depth (backstop on top of plugins/strip_columns.py):
# the datasette plugin strips protected columns from JSON, refuses CSV
# on protected tables, and refuses ?sql= queries. Caddy also blocks
# ?sql= and FTS shadow tables at the edge so the door stays shut even
# if the plugin ever silently fails to load (e.g. after a botched
# image deploy). The plugin still gates content; the Caddy block here
# is a fail-closed second layer. Owner-bypass requests carry an
# Authorization header and are NOT matched by @content_lockdown, so
# they still reach datasette and the plugin's actor_from_request hook
# maps the token to actor {id: owner}.
#
# Source: caddyserver.com/docs/caddyfile/matchers ("Multiple paths will be
#   OR'ed together"; *.suffix = "suffix match"; /prefix/* = "prefix match")
# Used by: docker-compose.yml caddy service, volume-mounted at
#   /etc/caddy/Caddyfile:ro
# DNS: relies on Compose's default project bridge network resolving
#   `zeeker-datasette` and `frontend` to container IPs.
#
# NOTE: /-/* is the datasette-reserved URL prefix. Frontend handlers
# MUST NOT register routes under /-/ because the @datasette matcher
# claims the entire prefix.
{
	# Local dev / phase 3: plain HTTP only. Production overlay
	# (docker-compose.prod.yml, future) will enable auto-HTTPS at the
	# real hostname data.zeeker.sg by adding a hostname site block
	# alongside this :80 block.
	auto_https off

	# Admin endpoint (default localhost:2019) stays internal to the
	# container. docker-compose.yml does NOT publish :2019 so this is
	# only reachable via `docker compose exec caddy ...` or the
	# container's own healthcheck.
	admin localhost:2019
}

:80 {
	# Block aggressive AI crawlers and scrapers that ignore robots.txt
	# and cause multi-day pagination surges, 503s, and server load.
	# 403 at Caddy layer before any proxy cost is incurred.
	@bad_bot header_regexp User-Agent "meta-externalagent|meta-webindexer|facebookexternalhit|FacebookBot|Barkrowler"
	respond @bad_bot "Forbidden" 403

	# Block ?sql= queries and FTS shadow tables at the edge before any
	# proxy hop. See Phase-D note in the file header.
	#
	# Caddy's matcher semantics: multiple matchers inside ONE @named
	# block are OR'd (e.g. several `path` lines); BUT mixing `path` and
	# `query` in the same block is AND'd (a request must satisfy BOTH
	# to match). To get a true OR of "has sql= query" OR "path contains
	# _fts*", we put each condition in its own @named matcher and write
	# a separate respond directive for each.
	#
	# Path matchers use the substring form (*_fts*) NOT the suffix form
	# (*_fts) because Datasette URLs always end in .json or .csv — a
	# suffix-match on _fts would only match paths that end in the bare
	# token, never the table-name patterns we want to block.
	@sql_query query sql=*
	@fts_shadow path *_fts* *_fts_data* *_fts_idx* *_fts_docsize* *_fts_config* *_fts_content* *_fts_segments* *_fts_segdir* *_fts_stat* *_fts_aux*
	respond @sql_query "Forbidden" 403
	respond @fts_shadow "Forbidden" 403

	# Suffix matcher for the data-API surface. Two `path` lines are OR'd
	# by Caddy (per caddyserver.com/docs/caddyfile/matchers); the first
	# is suffix globs, the second is the /-/* prefix glob.
	@datasette {
		path *.json *.csv
		path /-/*
	}
	# Matched requests → datasette (data API).
	reverse_proxy @datasette zeeker-datasette:8001
	# Catch-all → frontend. Caddy auto-sorts the no-matcher directive
	# last regardless of file order; we still write it second for
	# human readability.
	reverse_proxy frontend:8000
}
